# Copie este arquivo para .env.local e preencha os valores
# NÃO suba o .env.local para o GitHub — ele contém chaves secretas
# Na Vercel, configure essas mesmas variáveis em Settings → Environment Variables

# Chave da API-Football (https://api-football.com)
# Plano gratuito: 100 requisições/dia
API_FOOTBALL_KEY=sua_chave_aqui

# Chave da API da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sua_chave_aqui
